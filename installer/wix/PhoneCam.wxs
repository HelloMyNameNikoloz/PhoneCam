<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="PhoneCam"
    Manufacturer="PhoneCam Contributors"
    Version="$(var.ProductVersion)"
    UpgradeCode="{8D6F08D0-2D87-4A8C-92C8-4979D71E1772}"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of PhoneCam is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="PhoneCam" Level="1">
      <ComponentGroupRef Id="PhoneCamFiles" />
      <ComponentGroupRef Id="PhoneCamFilesAssets" />
      <ComponentGroupRef Id="PhoneCamCameraFiles" />
      <ComponentGroupRef Id="PhoneCamScriptFiles" />
      <ComponentRef Id="PhoneCamProgramData" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="InstallFolder" Name="PhoneCam">
        <Directory Id="AssetsFolder" Name="assets" />
        <Directory Id="CameraFolder" Name="camera" />
        <Directory Id="ToolsFolder" Name="tools" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PhoneCam" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ProgramDataPhoneCam" Name="PhoneCam" />
    </StandardDirectory>

    <ComponentGroup Id="PhoneCamFiles" Directory="InstallFolder">
      <Component Id="PhoneCamExe">
        <File Id="PhoneCamExeFile" Source="$(var.AppExe)" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="PhoneCamFilesAssets" Directory="AssetsFolder">
      <Component Id="PhoneCamCompanionApk">
        <File Source="$(var.CompanionApk)" Name="PhoneCamCompanion.apk" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="PhoneCamCameraFiles" Directory="CameraFolder">
      <Component Id="PhoneCamCameraCtl">
        <File Source="$(var.CameraDir)\PhoneCamCameraCtl.exe" KeyPath="yes" />
      </Component>
      <Component Id="PhoneCamMediaSource">
        <File Source="$(var.CameraDir)\PhoneCamVirtualCamera.dll" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="PhoneCamScriptFiles" Directory="ToolsFolder">
      <Component Id="PhoneCamRepairScript">
        <File Source="$(var.ToolsDir)\repair_virtual_camera.ps1" KeyPath="yes" />
      </Component>
      <Component Id="PhoneCamUninstallCameraScript">
        <File Source="$(var.ToolsDir)\uninstall_virtual_camera.ps1" KeyPath="yes" />
      </Component>
      <Component Id="PhoneCamDriverlessCommonScript">
        <File Source="$(var.ToolsDir)\driverless_camera_common.ps1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="PhoneCamProgramData" Directory="ProgramDataPhoneCam">
      <CreateFolder />
      <RemoveFile Id="RemoveFrameBuffer" Name="framebuffer.bin" On="uninstall" />
      <RemoveFile Id="RemoveNativeStats" Name="native_stats.bin" On="uninstall" />
      <RemoveFile Id="RemoveNativeSettings" Name="native_settings.txt" On="uninstall" />
      <RemoveFile Id="RemoveNativeLog" Name="native_camera.log" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\PhoneCam" Name="ProgramData" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder">
      <Shortcut Id="PhoneCamShortcut" Name="PhoneCam" Target="[InstallFolder]PhoneCam.exe" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\PhoneCam" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <CustomAction
      Id="RepairPhoneCamCamera"
      Directory="ToolsFolder"
      ExeCommand="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[ToolsFolder]repair_virtual_camera.ps1&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />
    <CustomAction
      Id="UninstallPhoneCamCamera"
      Directory="ToolsFolder"
      ExeCommand="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[ToolsFolder]uninstall_virtual_camera.ps1&quot;"
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="RepairPhoneCamCamera" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="UninstallPhoneCamCamera" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
